{
  "name": "@inbill/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "reset-owner-password": "bun run src/scripts/reset-owner-password.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@hono/zod-validator": "^0.4.3",
    "@inbill/shared": "workspace:*",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.7.10",
    "jose": "^5.10.0",
    "postgres": "^3.4.5",
    "resend": "^6.12.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3"
  }
}
