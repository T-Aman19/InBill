{
  "productName": "InBill",
  "version": "0.1.0",
  "identifier": "app.inbill.desktop",
  "build": {
    "frontendDist": "../../pos/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "(cd ../server && bun run dev &) && cd ../pos && bun run dev",
    "beforeBuildCommand": "cd ../server && bun run build && cd ../pos && bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "InBill POS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/inbill-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
